{
  "name": "robotrockalive-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon --exec 'node --experimental-strip-types' server/index.js\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon --exec 'node --experimental-strip-types' server/index.js",
    "build": "vite build && npx prisma generate",
    "start": "NODE_ENV=production node --experimental-strip-types server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:push": "npx prisma db push",
    "db:seed": "node --experimental-strip-types prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "vite": "^8.0.10"
  }
}
